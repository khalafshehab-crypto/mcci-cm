rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email != null);
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /employees/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /join_requests/{id} {
      allow read: if isVerifiedUser();
      // Allow public write but ONLY if it has an email and name field to prevent abuse
      allow write: if request.resource.data.keys().hasAll(['email', 'name']) 
                   && request.resource.data.email is string
                   && request.resource.data.name is string;
    }
    match /system_logs/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /committees/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /events/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /members/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /recommendations/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /tasks/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /templates/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /reports/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /kpis/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /org_structure/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /approved_emails/{id} {
      allow read, write: if isVerifiedUser();
    }
    
    match /assistant_sec_gen_events/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /assistant_sec_gen_tasks/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /centers_events/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /centers_tasks/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /affiliates_events/{id} {
      allow read, write: if isVerifiedUser();
    }
    match /affiliates_tasks/{id} {
      allow read, write: if isVerifiedUser();
    }
  }
}
